# Copy this to .env and fill in values
# NEVER commit .env to git

# Strong random secret for signing JWTs — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-random-hex-string

# OAuth 2.0 credentials for the MCP server — give these to Claude when adding the connector
# Generate CLIENT_ID with: node -e "console.log(require('crypto').randomUUID())"
# Generate CLIENT_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_CLIENT_ID=replace-with-uuid
OAUTH_CLIENT_SECRET=replace-with-32-byte-random-hex-string

# Port to listen on (Railway sets this automatically)
PORT=3000

# Set to 'production' on live server
NODE_ENV=development

CSRF_SECRET=replace-with-64-byte-random-hex-string

WEBAUTHN_RP_ID=ip-address-of-server

WEBAUTHN_RP_NAME=website-name